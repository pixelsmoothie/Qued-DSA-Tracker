{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Qued_v.1",
  "version": "1.0.0",
  "identifier": "com.qued.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Qued",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/pixelsmoothie/Qued-DSA-Tracker/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIwMjIyMEE0MzkzOTlDOTMKUldTVG5EazVwQ0Fpc1BFcjdaUDVuMjRSem40Z2thc0JBWHZTcnFaY05POXlQNm04Wmx2eVlZcGIK"
    },
    "notification": null,
    "dialog": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../guide.md"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      }
    }
  }
}